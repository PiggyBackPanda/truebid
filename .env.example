# ─────────────────────────────────────────────────────────────────────────────
# TrueBid — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Database — PostgreSQL (Prisma)
# Local dev example: postgresql://postgres:password@localhost:5432/truebid_dev
DATABASE_URL=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=
# IMPORTANT: Change to your production domain before deploying
NEXTAUTH_URL=http://localhost:3000

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Internal API ──────────────────────────────────────────────────────────────
# Used to authenticate internal job endpoints (e.g. QStash → send-unread-email)
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Cron secret ───────────────────────────────────────────────────────────────
# REQUIRED — protects /api/cron/* endpoints from public invocation.
# The cron scheduler (e.g. Vercel Cron, Upstash) must include this value
# in every request as: Authorization: Bearer <CRON_SECRET>
# The server will return 500 if this variable is unset — do NOT omit it.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ── AWS S3 — property image and document uploads ───────────────────────────
# https://console.aws.amazon.com/iam → create an IAM user with S3 permissions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=
# CloudFront distribution domain (e.g. https://abc123.cloudfront.net)
CLOUDFRONT_URL=

# ── Upstash Redis — rate limiting and session cache ────────────────────────
# https://console.upstash.com → create a Redis database → REST API tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Upstash QStash — delayed email jobs (production) ──────────────────────
# https://console.upstash.com → QStash tab
QSTASH_URL=
QSTASH_TOKEN=

# ── Redis — Socket.io adapter (production multi-instance) ─────────────────
# Standard Redis connection string, e.g. redis://user:pass@host:6379
# Not required for local development (falls back to in-memory adapter)
REDIS_URL=

# ── Resend — transactional email ──────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=TrueBid <noreply@truebid.com.au>

# ── Stripe — identity verification and payments ────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── GreenID — identity verification (alternative provider) ────────────────
# https://vixverify.com — contact GreenID for API credentials
GREENID_API_KEY=
GREENID_API_URL=

# ── Mapbox — property maps ─────────────────────────────────────────────────
# https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Anthropic — AI listing description generation ─────────────────────────
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ── PII Encryption ────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting verified identity names at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Dev feature flags ─────────────────────────────────────────────────────
# The "Dev: Mark as Verified" button is automatically active in development
# (NODE_ENV=development). No extra env var needed.
