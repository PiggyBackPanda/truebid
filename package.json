{
  "name": "truebid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "build": "next build",
    "start": "NODE_ENV=production ts-node --project tsconfig.server.json server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "ts-node --project tsconfig.server.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.server.json prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^5.22.0",
    "@stripe/stripe-js": "^9.0.0",
    "@types/pg": "^8.20.0",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^21.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
